{
  "entities": {
    "RLExperience": {
      "title": "RL Experience",
      "description": "Reinforcement learning experience data",
      "type": "object",
      "properties": {
        "totalEpisodes": {
          "type": "number"
        },
        "rewardsGathered": {
          "type": "number"
        }
      },
      "required": ["totalEpisodes", "rewardsGathered"]
    }
  },
  "firestore": {
    "/rl_experience/{docId}": {
      "schema": "RLExperience",
      "description": "RL experience data collection"
    }
  }
}
